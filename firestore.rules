rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner() {
      return isSignedIn() && request.auth.uid == resource.data.accountId;
    }
    function willOwn() {
      return isSignedIn() && request.auth.uid == request.resource.data.accountId;
    }
    function ownerUnchanged() {
      return request.resource.data.accountId == resource.data.accountId;
    }

    match /rssFeeds/{id} {
      allow read, delete: if isOwner();
      allow create: if willOwn();
      allow update: if isOwner() && ownerUnchanged();
    }

    match /contentIdeas/{id} {
      allow read, delete: if isOwner();
      allow create: if willOwn();
      allow update: if isOwner() && ownerUnchanged();
    }

    match /appConfig/{accountId} {
      allow read: if isSignedIn() && request.auth.uid == accountId;
      allow create, update: if isSignedIn()
        && request.auth.uid == accountId
        && request.resource.data.accountId == accountId;
      allow delete: if false;
    }

    match /drafts/{id} {
      allow read, delete: if isOwner();
      allow create: if willOwn();
      allow update: if isOwner() && ownerUnchanged();
    }

    match /chats/{chatId} {
      allow read, delete: if isOwner();
      allow create: if willOwn();
      allow update: if isOwner() && ownerUnchanged();

      match /messages/{messageId} {
        allow read: if isSignedIn()
          && request.auth.uid == get(/databases/$(database)/documents/chats/$(chatId)).data.accountId;
        // Writes happen via the Cloud Function (admin SDK bypasses rules);
        // keep client writes closed to prevent tampering.
        allow write: if false;
      }
    }
  }
}
