VITE_SENTRY_DSN=
VITE_API_BASE_URL=http://localhost:3000

# Firebase web app config (from Firebase console → Project settings → Your apps)
VITE_FIREBASE_API_KEY=AIza-your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abcdef0123456789
VITE_FIREBASE_FUNCTIONS_REGION=us-central1

# Set to "1" in dev to point auth/firestore/functions at the local emulators
VITE_FIREBASE_USE_EMULATOR=
