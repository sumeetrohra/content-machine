/**
 * Configuration options for the data table component.
 *
 * @template TData - The type of data displayed in each row
 */
type TDataTableConfig<TData> = {
  /** Column definitions for the table. */
  columns: Array<TColumnDef<TData>>;
  /** Whether to enable row selection via checkboxes. */
  selectable: boolean;
  /** Number of rows per page. Must be between 10 and 100. */
  pageSize: number;
};
