### Bad

```typescript
// No JSDoc at all
export const formatCurrency = (amount: number, currency: string) => { ... };

// JSDoc without required tags
/** Formats currency */
export const formatCurrency = (amount: number, currency: string) => { ... };

// Missing @param and @returns
/**
 * Formats a monetary value.
 */
export const formatCurrency = (amount: number, currency: string): string => { ... };

// No JSDoc on component
export const UserCard = ({ user }: TUserCardProps) => { ... };

// No JSDoc on type
export type TUserProfile = { id: string; name: string; };

// No JSDoc on enum
export enum EStatus { ACTIVE, INACTIVE }
```
